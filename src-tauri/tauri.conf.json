{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "CadMacro",
  "version": "0.1.1",
  "identifier": "com.cadmacro.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "CadMacro",
        "width": 980,
        "height": 680,
        "minWidth": 860,
        "minHeight": 580,
        "decorations": false,
        "resizable": true,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/viorizz/CADMacro/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEQzMTNDQUE1Qjc2NzYzQUQKUldTdFkyZTNwY29UMDUyM3Z1Rmt5NHFETTJmYjNpaGNabUFQcklkQllIVitmVzh3S2FReEZUNDEK"
    }
  }
}
